{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "test: vitest (run once)",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "test",
                "--",
                "--run"
            ],
            "options": {
                "cwd": "${workspaceFolder}/tourneyClient"
            }
        },
        {
            "label": "test: dotnet",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "test",
                "${workspaceFolder}/tourneyAPI.sln"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "validate: tests",
            "dependsOrder": "sequence",
            "dependsOn": [
                "test: vitest (run once)",
                "test: dotnet"
            ]
        }
    ]
}